static func get_npc_by_id(npc_id: String) -> Dictionary:
	for region_data in NPC_DATABASE.values():
		for npc in region_data.get("npcs", []):
			if npc.get("id") == npc_id:
				return npc
	return {}

static func get_npc_data(npc_id: String) -> Dictionary:
	return get_npc_by_id(npc_id)

static func get_npc_dialogue(npc_id: String, dialogue_index: int) -> String:
	var npc: Dictionary = get_npc_by_id(npc_id)
	var dialogues: Array = npc.get("dialogues", [])
	if dialogue_index < dialogues.size():
		return dialogues[dialogue_index]
	return ""

static func get_region_npcs(region: String) -> Array:
	if NPC_DATABASE.has(region):
		return NPC_DATABASE[region].get("npcs", [])
	return []
